# ACP Progress Visualizer — Environment Variables
# Copy to .env and customize

# Local data source (path to ACP Enhanced project's progress.yaml)
PROGRESS_YAML_PATH=../acp-enhanced/agent/progress.yaml

# Remote data source (GitHub repo — alternative to PROGRESS_YAML_PATH)
# PROGRESS_YAML_REPO=ssucipto/acp-enhanced:main

# GitHub personal access token for private repos
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Per-repo token env var (for multi-account GitHub setups)
# PROGRESS_YAML_TOKEN_ENV=GITHUB_TOKEN_MYORG

# Server port (default: auto-detect from 3000)
# PORT=3000

# Multi-project config (comma-separated name:path or name:repo)
# VISUALIZER_PROJECTS=acp-enhanced:../acp-enhanced/agent/progress.yaml,my-app:ssucipto/my-app
